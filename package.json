{
  "name": "photon-image-viewer",
  "productName": "Photon Image Viewer",
  "description": "Classic light-mode image viewer for macOS",
  "version": "0.0.6",
  "license": "MIT",
  "author": {
    "name": "sprout2000"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:sprout2000/photon-image-viewer.git"
  },
  "main": "dist/main.js",
  "scripts": {
    "dev": "rimraf dist && run-p dev:webpack dev:electron",
    "dev:webpack": "cross-env NODE_ENV=\"development\" webpack --progress",
    "dev:electron": "wait-on ./dist/index.html ./dist/main.js && electronmon .",
    "build": "rimraf dist && cross-env NODE_ENV=\"production\" webpack --progress",
    "package": "ts-node scripts/packager.ts"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "leaflet": "^1.9.4",
    "mime-types": "^3.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/leaflet": "^1.9.21",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "dotenv": "^17.4.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electronmon": "^2.0.4",
    "html-webpack-plugin": "^5.6.7",
    "mini-css-extract-plugin": "^2.10.2",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "ts-loader": "^9.6.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.10",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  }
}
