{
  "name": "photon-image-viewer",
  "productName": "Photon Image Viewer",
  "description": "Classic light-mode image viewer for macOS",
  "version": "0.0.6",
  "license": "MIT",
  "author": {
    "name": "sprout2000"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:sprout2000/photon-image-viewer.git"
  },
  "main": "dist/main.js",
  "scripts": {
    "dev": "rimraf dist && run-p dev:rspack dev:electron",
    "dev:rspack": "rspack --node-env \"development\"",
    "dev:electron": "wait-on ./dist/index.html ./dist/main.js && electronmon .",
    "build": "rimraf dist && rspack --node-env \"production\"",
    "package": "ts-node scripts/packager.ts"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "leaflet": "^1.9.4",
    "mime-types": "^3.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@rspack/cli": "^1.7.11",
    "@rspack/core": "^1.7.11",
    "@types/leaflet": "^1.9.21",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "css-loader": "^7.1.4",
    "dotenv": "^17.4.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "wait-on": "^9.0.4"
  }
}
